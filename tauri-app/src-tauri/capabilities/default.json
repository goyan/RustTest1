{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:window:allow-close",
    "core:window:allow-set-title",
    {
      "identifier": "fs:default",
      "allow": [{ "path": "**" }]
    },
    "fs:allow-read-dir",
    "fs:allow-read-file",
    "fs:allow-remove",
    "shell:allow-open"
  ]
}
